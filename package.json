{
  "name": "neurofunds",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node -e \"console.log('Skipping automatic prisma generate on install (run npm run prisma:generate manually).')\"",
    "prisma:generate": "prisma generate",
    "prisma:generate:force": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push",
    "clean:next": "powershell -Command \"Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue\"",
    "clean:prisma": "powershell -Command \"Remove-Item -Recurse -Force node_modules/.prisma -ErrorAction SilentlyContinue\"",
    "clean:install": "powershell -Command \"Remove-Item -Recurse -Force node_modules,.next -ErrorAction SilentlyContinue; Remove-Item -Force package-lock.json -ErrorAction SilentlyContinue\" && npm install",
    "reset:windows": "npm run clean:next && npm run clean:prisma && npm run prisma:generate"
  },
  "dependencies": {
    "@arcjet/next": "^1.0.0-beta.8",
    "@clerk/nextjs": "^6.23.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.1.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-email/components": "^0.1.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.19.1",
    "inngest": "^3.39.2",
    "lucide-react": "^0.523.0",
    "next": "14.2.30",
    "next-themes": "^0.4.6",
    "react": "18.2.0",
    "react-composer": "^5.0.3",
    "react-day-picker": "^9.7.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.58.1",
    "react-is": "^19.2.5",
    "react-spinners": "^0.17.0",
    "recharts": "^3.0.0",
    "resend": "^4.6.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.177.0",
    "vaul": "^1.1.2",
    "zod": "^3.25.67",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.30",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
