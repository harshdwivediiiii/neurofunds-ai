# ==============================
# NeuroFunds Environment Template
# ==============================

# Neon PostgreSQL (required)
# - DATABASE_URL: Neon pooled connection (runtime)
# - DIRECT_URL: Neon direct connection (migrations/db push)
#   Use the non-pooler endpoint for DIRECT_URL.
DATABASE_URL="postgresql://<user>:<password>@<pooled-host>.neon.tech/<db>?sslmode=require"
DIRECT_URL="postgresql://<user>:<password>@<direct-host>.neon.tech/<db>?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_or_test_..."
CLERK_SECRET_KEY="sk_live_or_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# AI + Email
GEMINI_API_KEY="..."
RESEND_API_KEY="..."

# Security
ARCJET_KEY="ajkey_..."
